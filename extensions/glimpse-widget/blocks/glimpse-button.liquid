{% liquid
  assign product = block.settings.product | default: product
  unless product
    assign product = product
  endunless
  
  assign product_id = product.id
  assign manual_shop_domain = block.settings.manual_shop_domain
  
  # Button styling
  assign button_style = block.settings.button_style | default: 'outlined'
  assign button_text = block.settings.button_text | default: 'TRY IT ON'
  assign button_text_case = block.settings.button_text_case | default: 'uppercase'
  assign button_border_radius = block.settings.button_border_radius | default: 50
  assign button_padding_x = block.settings.button_padding_x | default: 32
  assign button_padding_y = block.settings.button_padding_y | default: 16
  assign button_font_size = block.settings.button_font_size | default: 14
  assign button_font_weight = block.settings.button_font_weight | default: '500'
  assign show_camera_icon = block.settings.show_camera_icon
  assign button_width = block.settings.button_width | default: '100%'
  
  # Colors
  assign solid_button_color = block.settings.solid_button_color | default: '#1f2937'
  assign button_text_color = block.settings.button_text_color | default: '#1f2937'
  assign button_border_color = block.settings.button_border_color | default: '#d1d5db'
  assign button_border_width = block.settings.button_border_width | default: 1
  
  # Results styling
  assign results_background = block.settings.results_background | default: '#ffffff'
  assign image_border_radius = block.settings.image_border_radius | default: 8
  
  # Layout
  assign widget_margin_top = block.settings.widget_margin_top | default: 10
  assign widget_margin_bottom = block.settings.widget_margin_bottom | default: 10
  assign button_alignment = block.settings.button_alignment | default: 'center'
%}

<!-- Gleame Button Widget -->
<div class="glimpse-button-widget" 
     data-product-id="{{ product_id }}"
     data-block-id="{{ block.id }}"
     data-button-text="{{ button_text }}"
     data-cart-token="{{ cart.token }}"{% if manual_shop_domain != blank %}
     data-manual-shop-domain="{{ manual_shop_domain }}"{% endif %}
     style="--solid-button-color: {{ solid_button_color }};
            --button-text-color: {{ button_text_color }};
            --button-border-color: {{ button_border_color }};
            --button-border-width: {{ button_border_width }}px;
            --button-border-radius: {{ button_border_radius }}px;
            --button-padding-x: {{ button_padding_x }}px;
            --button-padding-y: {{ button_padding_y }}px;
            --button-font-size: {{ button_font_size }}px;
            --button-font-weight: {{ button_font_weight }};
            --button-text-case: {{ button_text_case }};
            --button-width: {{ button_width }};
            --results-background: {{ results_background }};
            --image-border-radius: {{ image_border_radius }}px;
            --widget-margin-top: {{ widget_margin_top }}px;
            --widget-margin-bottom: {{ widget_margin_bottom }}px;
            --button-alignment: {{ button_alignment }};">
  
  <!-- Button (Always Visible) -->
  <div class="button-container">
    <button class="glimpse-btn btn-style-{{ button_style }}" 
            id="mainButton-{{ block.id }}"
            type="button" 
            onclick="window.glimpseButton.triggerUpload('{{ block.id }}')">
      {% if show_camera_icon %}
        <svg class="btn-icon btn-camera-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/>
          <circle cx="12" cy="13" r="3"/>
        </svg>
      {% endif %}
      <span class="btn-spinner" style="display: none;"></span>
      <span class="btn-text">{{ button_text }}</span>
    </button>
  </div>
  
  <!-- Hidden file input -->
  <input type="file" 
         id="imageUpload-{{ block.id }}" 
         accept="image/*,.heic,.heif" 
         style="display: none;">
  
  <!-- Results Modal Overlay -->
  <div class="results-modal-overlay" id="resultsModal-{{ block.id }}" style="display: none;">
    <div class="results-modal" style="background: {{ results_background }}; --modal-image-radius: {{ image_border_radius }}px;">
      <button class="modal-close-btn" type="button" onclick="window.glimpseButton.closeResults('{{ block.id }}')">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 6L6 18"/>
          <path d="M6 6l12 12"/>
        </svg>
      </button>
      <div class="modal-content">
        <div class="modal-header">
          <h2 class="modal-title">Your personalized preview</h2>
          <p class="modal-subtitle">Generated based on your photo and this product</p>
        </div>
        <div class="modal-comparison-card">
          <div class="modal-comparison">
            <div class="modal-comparison-side">
              <span class="comparison-label">BEFORE</span>
              <img id="beforeImage-{{ block.id }}" alt="Before" class="modal-result-img" width="200" height="200">
            </div>
            <div class="modal-divider">
              <div class="divider-line"></div>
            </div>
            <div class="modal-comparison-side">
              <span class="comparison-label">AFTER</span>
              <img id="afterImage-{{ block.id }}" alt="After" class="modal-result-img" width="200" height="200">
            </div>
          </div>
        </div>
        <p class="modal-disclaimer">Results may vary. Preview is a visual simulation.</p>
        <div class="modal-actions">
          <button class="modal-btn modal-btn-secondary" type="button" onclick="window.glimpseButton.tryAgain('{{ block.id }}')">
            Try a different photo
          </button>
          <button class="modal-btn modal-btn-primary" type="button" onclick="window.glimpseButton.closeResults('{{ block.id }}')">
            Close
          </button>
        </div>
        <div class="modal-powered-by">Powered by <strong>Gleame</strong></div>
      </div>
    </div>
  </div>
  
  <!-- Error Modal Overlay -->
  <div class="error-modal-overlay" id="errorModal-{{ block.id }}" style="display: none;">
    <div class="error-modal">
      <button class="modal-close-btn" type="button" onclick="window.glimpseButton.closeError('{{ block.id }}')">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 6L6 18"/>
          <path d="M6 6l12 12"/>
        </svg>
      </button>
      <div class="modal-content">
        <p class="modal-error-message" id="errorMessage-{{ block.id }}"></p>
        <button class="glimpse-btn btn-style-{{ button_style }}" 
                type="button" 
                onclick="window.glimpseButton.tryAgain('{{ block.id }}')">
          <span class="btn-text">Try Again</span>
        </button>
      </div>
    </div>
  </div>
  
</div>

<link rel="stylesheet" href="{{ 'gleame-camera.css' | asset_url }}">
<script src="{{ 'gleame-camera.js' | asset_url }}" defer></script>
<script src="{{ 'glimpse-button.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Gleame Button",
  "target": "section",
  "stylesheet": "glimpse-button.css",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product",
      "autofill": true
    },
    {
      "type": "header",
      "content": "Configuration"
    },
    {
      "type": "text",
      "id": "manual_shop_domain",
      "label": "Shop Domain (Optional)",
      "placeholder": "shop123.myshopify.com",
      "info": "If using a custom domain, enter your .myshopify.com domain here."
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "TRY IT ON"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button Style",
      "default": "outlined",
      "options": [
        { "value": "solid", "label": "Solid Filled" },
        { "value": "outlined", "label": "Outlined" }
      ]
    },
    {
      "type": "select",
      "id": "button_text_case",
      "label": "Text Case",
      "default": "uppercase",
      "options": [
        { "value": "none", "label": "As Typed" },
        { "value": "uppercase", "label": "UPPERCASE" },
        { "value": "lowercase", "label": "lowercase" },
        { "value": "capitalize", "label": "Capitalize" }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_camera_icon",
      "label": "Show Camera Icon",
      "default": false
    },
    {
      "type": "select",
      "id": "button_width",
      "label": "Button Width",
      "default": "100%",
      "options": [
        { "value": "auto", "label": "Auto (fit content)" },
        { "value": "100%", "label": "Full Width" },
        { "value": "200px", "label": "200px" },
        { "value": "250px", "label": "250px" },
        { "value": "300px", "label": "300px" }
      ]
    },
    {
      "type": "select",
      "id": "button_alignment",
      "label": "Button Alignment",
      "default": "center",
      "options": [
        { "value": "flex-start", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Right" }
      ]
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Corner Radius (px)",
      "min": 0,
      "max": 50,
      "step": 2,
      "default": 50,
      "info": "50 = pill shape"
    },
    {
      "type": "range",
      "id": "button_padding_x",
      "label": "Horizontal Padding (px)",
      "min": 16,
      "max": 64,
      "step": 4,
      "default": 32
    },
    {
      "type": "range",
      "id": "button_padding_y",
      "label": "Vertical Padding (px)",
      "min": 8,
      "max": 32,
      "step": 2,
      "default": 16
    },
    {
      "type": "range",
      "id": "button_font_size",
      "label": "Font Size (px)",
      "min": 12,
      "max": 24,
      "step": 1,
      "default": 14
    },
    {
      "type": "select",
      "id": "button_font_weight",
      "label": "Font Weight",
      "default": "500",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" }
      ]
    },
    {
      "type": "range",
      "id": "button_border_width",
      "label": "Border Width (px)",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 1,
      "info": "For outlined style"
    },
    {
      "type": "color",
      "id": "solid_button_color",
      "label": "Button Fill Color",
      "default": "#1f2937",
      "info": "Background color for solid-style button"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text Color",
      "default": "#1f2937",
      "info": "For outlined style (solid uses white text)"
    },
    {
      "type": "color",
      "id": "button_border_color",
      "label": "Button Border Color",
      "default": "#d1d5db",
      "info": "For outlined style"
    },
    {
      "type": "header",
      "content": "Results Modal"
    },
    {
      "type": "color",
      "id": "results_background",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Image Corner Radius (px)",
      "min": 0,
      "max": 20,
      "step": 2,
      "default": 8
    },
    {
      "type": "header",
      "content": "Widget Layout"
    },
    {
      "type": "range",
      "id": "widget_margin_top",
      "label": "Margin Top (px)",
      "min": -25,
      "max": 50,
      "step": 5,
      "default": 10,
      "info": "Use negative values to pull closer to content above"
    },
    {
      "type": "range",
      "id": "widget_margin_bottom",
      "label": "Margin Bottom (px)",
      "min": -25,
      "max": 50,
      "step": 5,
      "default": 10
    }
  ]
}
{% endschema %}

