{% liquid
  assign product = block.settings.product | default: product
  unless product
    assign product = product
  endunless
  
  assign product_id = product.id
%}

<!-- Try It On Button (always visible) -->
<div class="beauty-transformation-trigger" data-product-id="{{ product_id }}">
  <button class="try-it-on-btn" type="button" onclick="console.log('Button clicked!'); openTransformationModal('{{ product_id }}', '{{ product.title | escape }}');">
    <span class="try-it-icon">✨</span>
    {{ block.settings.button_text }}
  </button>
</div>

<!-- Modal (hidden by default) -->
<div class="transformation-modal-overlay" id="transformationModal" style="display: none;">
  <div class="transformation-modal">
    <div class="modal-header">
      <h3 id="modalProductTitle">{{ block.settings.widget_title }}</h3>
      <button class="modal-close" onclick="closeTransformationModal()">&times;</button>
    </div>
    
    <div class="modal-content">
      <p class="modal-description">{{ block.settings.widget_description }}</p>
      
      <!-- Upload Section -->
      <div class="upload-section" id="uploadSection">
        <div class="upload-dropzone" id="uploadDropzone">
          <div class="upload-icon">📷</div>
          <p class="upload-text">{{ 'transformation.upload_text' | t: default: 'Upload your photo to see how you will look!' }}</p>
          <p class="upload-subtext">{{ 'transformation.upload_subtext' | t: default: 'Supports JPG, PNG files up to 5MB' }}</p>
          <input type="file" id="imageUpload" accept="image/*" style="display: none;">
          <button class="upload-button" type="button">
            {{ 'transformation.choose_photo' | t: default: 'Choose Photo' }}
          </button>
        </div>
      </div>

      <!-- Processing Section -->
      <div class="processing-section" id="processingSection" style="display: none;">
        <div class="loading-spinner"></div>
        <p>{{ 'transformation.processing' | t: default: 'Creating your transformation...' }}</p>
      </div>

      <!-- Results Section -->
      <div class="results-section" id="resultsSection" style="display: none;">
        <div class="before-after-container">
          <div class="image-container">
            <h4>{{ 'transformation.before' | t: default: 'Before' }}</h4>
            <img id="beforeImage" alt="Before transformation" width="150" height="150">
          </div>
          <div class="image-container">
            <h4>{{ 'transformation.after' | t: default: 'After' }}</h4>
            <img id="afterImage" alt="After transformation" width="150" height="150">
          </div>
        </div>
        
        <div class="result-actions">
          <button class="try-another-btn" onclick="window.widgetFunctions.resetTransformation()">
            {{ 'transformation.try_another' | t: default: 'Try Another Photo' }}
          </button>
          <button class="add-to-cart-btn" onclick="window.widgetFunctions.addToCartAndClose()">
            {{ 'transformation.add_to_cart' | t: default: 'Add to Cart' }}
          </button>
        </div>
      </div>

      <!-- Error Section -->
      <div class="error-section" id="errorSection" style="display: none;">
        <p class="error-message" id="errorMessage"></p>
        <button class="try-again-btn" onclick="window.widgetFunctions.resetTransformation()">
          {{ 'transformation.try_again' | t: default: 'Try Again' }}
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  // Global namespace for widget functions
  window.widgetFunctions = window.widgetFunctions || {};
  
  let currentProductId = null;
  let currentShopDomain = null;
  
  // =====================================================
  // CONFIGURATION: Update this URL to your deployed app
  const SHOPIFY_APP_URL = 'https://glimpse-app-9zjc.onrender.com';
  // =====================================================
  
  // Auto-detect shop domain from current URL
  function getShopDomain() {
    const hostname = window.location.hostname;
    if (hostname.includes('.myshopify.com')) {
      return hostname;
    }
    // For custom domains, we might need to find the shop domain differently
    // For now, we'll extract it from the Shopify scripts or other indicators
    const shopifyScripts = document.querySelectorAll('script[src*="myshopify.com"]');
    if (shopifyScripts.length > 0) {
      const scriptSrc = shopifyScripts[0].src;
      const match = scriptSrc.match(/\/\/([^\/]+\.myshopify\.com)/);
      if (match) return match[1];
    }
    return hostname; // Fallback to current hostname
  }
  
  // Global functions for the widget
  window.openTransformationModal = function(productId, productTitle) {
    console.log('=== OPENING MODAL ===');
    console.log('Product ID:', productId);
    console.log('Product Title:', productTitle);
    
    try {
      currentProductId = productId;
      currentShopDomain = getShopDomain();
      
      console.log('Shop domain detected:', currentShopDomain);
      console.log('App URL:', SHOPIFY_APP_URL);
      
      const modal = document.getElementById('transformationModal');
      const titleElement = document.getElementById('modalProductTitle');
      
      if (!modal) {
        console.error('Modal element not found!');
        return;
      }
      
      if (!titleElement) {
        console.error('Modal title element not found!');
        return;
      }
      
      titleElement.textContent = productTitle;
      modal.style.display = 'flex';
      document.body.style.overflow = 'hidden'; // Prevent background scrolling
      
      console.log('Modal opened successfully');
      window.widgetFunctions.resetTransformation();
    } catch (error) {
      console.error('Error opening modal:', error);
    }
  };
  
  window.closeTransformationModal = function() {
    document.getElementById('transformationModal').style.display = 'none';
    document.body.style.overflow = 'auto';
    window.widgetFunctions.resetTransformation();
  };
  
  window.widgetFunctions.resetTransformation = function() {
    console.log('Resetting transformation');
    const imageUpload = document.getElementById('imageUpload');
    const beforeImage = document.getElementById('beforeImage');
    const afterImage = document.getElementById('afterImage');
    
    if (imageUpload) imageUpload.value = '';
    if (beforeImage) beforeImage.src = '';
    if (afterImage) afterImage.src = '';
    
    window.widgetFunctions.showSection('upload');
  };
  
  window.widgetFunctions.addToCartAndClose = function() {
    // Find the add to cart form
    const form = document.querySelector('form[action*="/cart/add"]');
    if (form) {
      // Close modal first
      closeTransformationModal();
      // Then submit form
      setTimeout(() => form.submit(), 100);
    } else {
      // Fallback - just close modal
      closeTransformationModal();
    }
  };

  window.widgetFunctions.showSection = function(section) {
    console.log('Showing section:', section);
    const sections = ['upload', 'processing', 'results', 'error'];
    sections.forEach(s => {
      const el = document.getElementById(`${s}Section`);
      if (el) {
        el.style.display = s === section ? 'block' : 'none';
      }
    });
  };

  window.widgetFunctions.showError = function(message) {
    console.error('Widget error:', message);
    document.getElementById('errorMessage').textContent = message;
    window.widgetFunctions.showSection('error');
  };

  document.addEventListener('DOMContentLoaded', function() {
    console.log('Widget loaded');
    
    const imageUpload = document.getElementById('imageUpload');
    const beforeImage = document.getElementById('beforeImage');
    const afterImage = document.getElementById('afterImage');
    
    // Ensure elements exist before adding event listeners
    if (!imageUpload || !beforeImage || !afterImage) {
      console.error('Required widget elements not found');
      return;
    }
    
    // Handle file upload
    imageUpload.addEventListener('change', handleImageUpload);
    
    // Handle dropzone clicks and drag-and-drop
    const uploadDropzone = document.getElementById('uploadDropzone');
    const uploadButton = document.querySelector('.upload-button');
    
    if (uploadDropzone) {
      uploadDropzone.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        console.log('Dropzone clicked');
        imageUpload.click();
      });
      
      // Prevent default drag behaviors
      ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
        uploadDropzone.addEventListener(eventName, (e) => {
          e.preventDefault();
          e.stopPropagation();
        }, false);
      });
      
      // Highlight drop area when dragging over it
      ['dragenter', 'dragover'].forEach(eventName => {
        uploadDropzone.addEventListener(eventName, () => {
          uploadDropzone.style.borderColor = '#8b5cf6';
          uploadDropzone.style.background = '#f3f0ff';
        }, false);
      });
      
      ['dragleave', 'drop'].forEach(eventName => {
        uploadDropzone.addEventListener(eventName, () => {
          uploadDropzone.style.borderColor = '#d1d5db';
          uploadDropzone.style.background = '#fafbfb';
        }, false);
      });
      
      // Handle dropped files
      uploadDropzone.addEventListener('drop', (e) => {
        const files = Array.from(e.dataTransfer.files);
        if (files.length > 0) {
          console.log('Files dropped:', files.length);
          // Simulate file input change event
          const fakeEvent = {
            target: {
              files: [files[0]],
              value: ''
            }
          };
          handleImageUpload(fakeEvent);
        }
      }, false);
    }
    
    // Handle upload button clicks specifically
    if (uploadButton) {
      uploadButton.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        console.log('Upload button clicked');
        imageUpload.click();
      });
    }
    
    function handleImageUpload(event) {
      const file = event.target.files[0];
      if (!file) {
        console.log('No file selected');
        return;
      }
      
      console.log('File selected:', file.name, 'Size:', file.size, 'Type:', file.type);
      
      // Reset any previous errors
      window.widgetFunctions.showSection('upload');
      
      // Validate file type
      const allowedTypes = ['image/jpeg', 'image/jpg', 'image/png', 'image/webp'];
      if (!allowedTypes.includes(file.type.toLowerCase())) {
        console.error('Invalid file type:', file.type);
        window.widgetFunctions.showError('Please upload a JPG, PNG, or WebP image.');
        // Clear the input so user can try again
        event.target.value = '';
        return;
      }
      
      // Validate file size (5MB limit for storefront)
      const maxSize = 5 * 1024 * 1024;
      if (file.size > maxSize) {
        console.error('File too large:', file.size, 'Max:', maxSize);
        window.widgetFunctions.showError('Image too large. Please upload an image smaller than 5MB.');
        // Clear the input so user can try again
        event.target.value = '';
        return;
      }
      
      // Validate file is actually an image by checking for image data
      if (file.size === 0) {
        console.error('Empty file');
        window.widgetFunctions.showError('The selected file appears to be empty. Please try another image.');
        event.target.value = '';
        return;
      }
      
      // Show preview and start transformation
      const reader = new FileReader();
      
      reader.onload = function(e) {
        try {
          console.log('File read successfully, data length:', e.target.result.length);
          beforeImage.src = e.target.result;
          
          // Start transformation after a small delay to ensure image is displayed
          setTimeout(() => {
            transformImage(file);
          }, 100);
        } catch (error) {
          console.error('Error setting image preview:', error);
          window.widgetFunctions.showError('Error loading image preview. Please try again.');
          event.target.value = '';
        }
      };
      
      reader.onerror = function(error) {
        console.error('FileReader error:', error);
        window.widgetFunctions.showError('Error reading the image file. Please try again.');
        event.target.value = '';
      };
      
      reader.onabort = function() {
        console.log('FileReader aborted');
        window.widgetFunctions.showError('File reading was interrupted. Please try again.');
        event.target.value = '';
      };
      
      // Read the file as data URL
      try {
        reader.readAsDataURL(file);
      } catch (error) {
        console.error('Error starting file read:', error);
        window.widgetFunctions.showError('Error reading the image file. Please try again.');
        event.target.value = '';
      }
    }
    
    async function transformImage(file) {
      window.widgetFunctions.showSection('processing');
      
      try {
        console.log('=== STARTING TRANSFORMATION ===');
        console.log('Product ID:', currentProductId);
        console.log('Shop domain:', currentShopDomain);
        console.log('File name:', file.name);
        console.log('File size:', file.size);
        console.log('File type:', file.type);
        console.log('Current location:', window.location.href);
        console.log('Using app URL:', SHOPIFY_APP_URL);
        
        // Validate configuration
        if (!currentShopDomain) {
          throw new Error('Could not determine shop domain. Please refresh the page and try again.');
        }
        
        if (!SHOPIFY_APP_URL) {
          throw new Error('App URL not configured. Please update the APP_URL in the widget code.');
        }
        
        const formData = new FormData();
        formData.append('image', file);
        formData.append('productId', currentProductId);
        formData.append('shopDomain', currentShopDomain);
        
        console.log('FormData contents:');
        for (let [key, value] of formData.entries()) {
          console.log('-', key + ':', typeof value === 'object' ? value.name : value);
        }
        
        // Use the app's domain for API calls
        const apiUrl = SHOPIFY_APP_URL.endsWith('/') 
          ? SHOPIFY_APP_URL + 'api/storefront/transform-image'
          : SHOPIFY_APP_URL + '/api/storefront/transform-image';
        
        console.log('Making API request to:', apiUrl);
        
        const response = await fetch(apiUrl, {
          method: 'POST',
          body: formData,
          headers: {
            'X-Requested-With': 'XMLHttpRequest'
          }
        });
        
        console.log('=== API RESPONSE ===');
        console.log('Status:', response.status);
        console.log('Status text:', response.statusText);
        console.log('Headers:', Object.fromEntries(response.headers.entries()));
        
        let result;
        const responseText = await response.text();
        console.log('Raw response body:', responseText);
        console.log('Response length:', responseText.length);
        
        try {
          result = JSON.parse(responseText);
          console.log('Parsed result:', result);
        } catch (parseError) {
          console.error('JSON parse error:', parseError);
          console.error('Failed to parse response:', responseText.substring(0, 500));
          throw new Error('Invalid server response. Please try again.');
        }
        
        if (!response.ok) {
          throw new Error(result.error || `Server error: ${response.status}`);
        }
        
        if (!result.success) {
          throw new Error(result.error || 'Transformation failed');
        }
        
        if (!result.generatedImage) {
          throw new Error('No transformed image received');
        }
        
        // Show result
        afterImage.src = `data:image/jpeg;base64,${result.generatedImage}`;
        window.widgetFunctions.showSection('results');
        
        console.log('Transformation completed successfully!');
        
      } catch (error) {
        console.error('Transformation error:', error);
        window.widgetFunctions.showError(error.message || 'Something went wrong. Please try again.');
      }
    }
    
    // Close modal when clicking overlay
    document.getElementById('transformationModal').addEventListener('click', function(e) {
      if (e.target === this) {
        closeTransformationModal();
      }
    });
    
    // Close modal with Escape key
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && document.getElementById('transformationModal').style.display === 'flex') {
        closeTransformationModal();
      }
    });
  });
</script>

{% schema %}
{
  "name": "AI Beauty Transformation",
  "target": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "stylesheet": "transformation-widget.css",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product",
      "autofill": true
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Try It On"
    },
    {
      "type": "text",
      "id": "widget_title",
      "label": "Modal Title",
      "default": "See How You'll Look!"
    },
    {
      "type": "textarea",
      "id": "widget_description",
      "label": "Modal Description",
      "default": "Upload your photo and see how this product will look on you with AI-powered transformation."
    }
  ]
}
{% endschema %} 