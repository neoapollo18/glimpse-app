{% liquid
  assign product = block.settings.product | default: product
  unless product
    assign product = product
  endunless
  
  assign product_id = product.id
  
  # Use custom colors or defaults
  assign primary_color_1 = block.settings.primary_color_1 | default: '#1f2937'
  assign primary_color_2 = block.settings.primary_color_2 | default: '#111827'
  assign caption_color_1 = block.settings.caption_color_1 | default: '#6b7280'
  assign caption_color_2 = block.settings.caption_color_2 | default: '#9ca3af'
  assign icon_color = block.settings.icon_color | default: '#1f2937'
  assign background_color = block.settings.background_color | default: '#ffffff'
  assign text_color = block.settings.text_color | default: '#1f2937'
  assign button_text_color = block.settings.button_text_color | default: '#ffffff'
  assign manual_shop_domain = block.settings.manual_shop_domain
  
  # Customization variables
  assign widget_margin_top = block.settings.widget_margin_top | default: 20
  assign widget_margin_bottom = block.settings.widget_margin_bottom | default: 20
  assign title_font_size = block.settings.title_font_size | default: 24
  assign description_font_size = block.settings.description_font_size | default: 16
  assign disclaimer_text = block.settings.disclaimer_text | default: 'Results are not guaranteed, just a generated image. Images are never saved.'
  
  # Font customization variables
  assign header_font_family = block.settings.header_font_family | default: 'inherit'
  assign header_font_weight = block.settings.header_font_weight | default: 'inherit'
  assign body_font_family = block.settings.body_font_family | default: 'inherit'
  assign body_font_weight = block.settings.body_font_weight | default: 'inherit'
  
  # Shadow customization
  assign enable_widget_shadow = block.settings.enable_widget_shadow
  if enable_widget_shadow == false
    assign widget_shadow = 'none'
  else
    assign widget_shadow = '0 4px 20px rgba(0, 0, 0, 0.1)'
  endif
  
  # Widget container corner radius customization
  assign widget_border_radius = block.settings.widget_border_radius | default: 16
%}

<!-- Gleame AI Transformation Widget -->
<div class="glimpse-ai-widget{% if block.settings.layout_orientation == 'horizontal' %} layout-horizontal{% endif %}" 
     data-product-id="{{ product_id }}"
     data-block-id="{{ block.id }}"{% if manual_shop_domain != blank %}
     data-manual-shop-domain="{{ manual_shop_domain }}"{% endif %}
     style="--primary-color-1: {{ primary_color_1 }}; 
            --primary-color-2: {{ primary_color_2 }};
            --caption-color-1: {{ caption_color_1 }};
            --caption-color-2: {{ caption_color_2 }};
            --icon-color: {{ icon_color }};
            --widget-border-radius: {{ widget_border_radius }}px;
            --background-color: {{ background_color }}; 
            --text-color: {{ text_color }};
            --button-text-color: {{ button_text_color }};
            --widget-margin-top: {{ widget_margin_top }}px;
            --widget-margin-bottom: {{ widget_margin_bottom }}px;
            --title-font-size: {{ title_font_size }}px;
            --description-font-size: {{ description_font_size }}px;
            --button-shadow-color: {{ primary_color_1 }};
            --header-font-family: {{ header_font_family }};
            --header-font-weight: {{ header_font_weight }};
            --body-font-family: {{ body_font_family }};
            --body-font-weight: {{ body_font_weight }};
            --widget-shadow: {{ widget_shadow }};">
  
  <!-- Desktop Left Section -->
  <div class="widget-left">
    <!-- Widget Header -->
    <div class="widget-header">
      <h2 class="widget-title">{{ block.settings.widget_title | default: "See My Glowup!" }}</h2>
      
      <!-- Star Icon -->
      <div class="star-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-sparkle-icon lucide-sparkle"><path d="M11.017 2.814a1 1 0 0 1 1.966 0l1.051 5.558a2 2 0 0 0 1.594 1.594l5.558 1.051a1 1 0 0 1 0 1.966l-5.558 1.051a2 2 0 0 0-1.594 1.594l-1.051 5.558a1 1 0 0 1-1.966 0l-1.051-5.558a2 2 0 0 0-1.594-1.594l-5.558-1.051a1 1 0 0 1 0-1.966l5.558-1.051a2 2 0 0 0 1.594-1.594z"/></svg>
      </div>
      
      <p class="widget-description">{{ block.settings.widget_description | default: "Upload an image of yourself and see your transformation" }}</p>
    </div>
    
    <!-- Widget Footer (Desktop Left) -->
    <div class="widget-footer">
      <div class="info-icon-container">
        <svg class="info-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <path d="M12 16v-4"/>
          <path d="M12 8h.01"/>
        </svg>
      </div>
      <p class="disclaimer">
        {{ disclaimer_text }}
      </p>
    </div>
  </div>
  
  <!-- Desktop Right Section / Mobile Full Width -->
  <div class="widget-right">
    <!-- Widget Content Area -->
    <div class="widget-content">
    
    <!-- Initial/Upload State -->
    <div class="upload-state" id="uploadState-{{ block.id }}">
      <div class="placeholder-image-container" onclick="window.widgetFunctions.triggerFileInput('{{ block.id }}')">
        {% if block.settings.placeholder_image %}
          <img src="{{ block.settings.placeholder_image | image_url: width: 400 }}" 
               alt="Transformation preview" 
               class="placeholder-image"
               width="400"
               height="200">
        {% else %}
          <div class="default-placeholder">
            <div class="placeholder-split">
              <div class="placeholder-half placeholder-before">
                <div class="placeholder-silhouette"></div>
              </div>
              <div class="placeholder-half placeholder-after">
                <div class="placeholder-silhouette placeholder-silhouette-glow"></div>
              </div>
            </div>
          </div>
        {% endif %}
      </div>
      
      <input type="file" 
             id="imageUpload-{{ block.id }}" 
             accept="image/*,.heic,.heif" 
             style="display: none;">
      
      <button class="upload-button" 
              type="button" 
              onclick="window.widgetFunctions.triggerFileInput('{{ block.id }}')">
        {{ block.settings.button_text | default: "Take A Photo" }}
      </button>
    </div>
    
    <!-- Processing State -->
    <div class="processing-state" id="processingState-{{ block.id }}" style="display: none;">
      <div class="loading-container">
        <div class="loading-spinner"></div>
        <p class="loading-text">Analyzing image...</p>
      </div>
    </div>
    
    <!-- Results State -->
    <div class="results-state" id="resultsState-{{ block.id }}" style="display: none;">
      <div class="before-after-grid">
        <div class="image-comparison">
          <div class="comparison-item">
            <div class="image-label">{{ 'transformation.me' | t: default: 'Me' }}</div>
            <img id="beforeImage-{{ block.id }}" alt="Before transformation" class="comparison-image" width="150" height="150">
          </div>
          <div class="comparison-item">
            <div class="image-label">{{ 'transformation.future_me' | t: default: 'Future Me' }}</div>
            <img id="afterImage-{{ block.id }}" alt="After transformation" class="comparison-image" width="150" height="150">
          </div>
        </div>
      </div>
      
      <div class="results-actions">
        <button class="retry-button" 
                type="button" 
                onclick="window.widgetFunctions.resetTransformation('{{ block.id }}')">
          <svg class="retry-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/>
            <path d="M21 3v5h-5"/>
            <path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/>
            <path d="M3 21v-5h5"/>
          </svg>
          {{ 'transformation.retry' | t: default: 'Retry' }}
        </button>
      </div>
    </div>
    
    <!-- Error State -->
    <div class="error-state" id="errorState-{{ block.id }}" style="display: none;">
      <div class="error-container">
        <svg class="error-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 9v4"/>
          <path d="M12 17h.01"/>
          <path d="M3 7v12a1 1 0 0 0 1 1h16a1 1 0 0 0 1-1V7a1 1 0 0 0-1-1H4a1 1 0 0 0-1 1z"/>
          <path d="M21 7 12 2 3 7"/>
        </svg>
        <p class="error-message" id="errorMessage-{{ block.id }}"></p>
        <button class="retry-button" 
                type="button" 
                onclick="window.widgetFunctions.resetTransformation('{{ block.id }}')">
          <svg class="retry-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/>
            <path d="M21 3v5h-5"/>
            <path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/>
            <path d="M3 21v-5h5"/>
          </svg>
          {{ 'transformation.try_again' | t: default: 'Try Again' }}
        </button>
      </div>
    </div>
    
    <!-- Widget Footer (Mobile/Tablet) -->
    <div class="widget-footer widget-footer-mobile">
      <div class="info-icon-container">
        <svg class="info-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <path d="M12 16v-4"/>
          <path d="M12 8h.01"/>
        </svg>
      </div>
      <p class="disclaimer">
        {{ disclaimer_text }}
      </p>
    </div>
    
    </div>
  </div>
  
</div>

<script src="{{ 'widget.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Gleame Legacy",
  "target": "section",
  "stylesheet": "transformation-widget.css",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product",
      "autofill": true
    },
    {
      "type": "header",
      "content": "Configuration"
    },
    {
      "type": "select",
      "id": "layout_orientation",
      "label": "Layout Orientation",
      "options": [
        {
          "value": "vertical",
          "label": "Vertical"
        },
        {
          "value": "horizontal",
          "label": "Horizontal"
        }
      ],
      "default": "vertical",
      "info": "Choose between vertical (stacked) or horizontal (side-by-side) layout"
    },
    {
      "type": "text",
      "id": "manual_shop_domain",
      "label": "Shop Domain (Optional)",
      "placeholder": "shop123.myshopify.com",
      "info": "If you're using a custom domain and experiencing issues, manually enter your .myshopify.com domain here."
    },
    {
      "type": "header",
      "content": "Title"
    },
    {
      "type": "text",
      "id": "widget_title",
      "label": "Title Text",
      "default": "See My Glowup!"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Title Color",
      "default": "#1f2937",
      "info": "Main text color for titles"
    },
    {
      "type": "range",
      "id": "title_font_size",
      "label": "Title Font Size (px)",
      "min": 12,
      "max": 48,
      "step": 2,
      "default": 24,
      "info": "Size of the widget title text"
    },
    {
      "type": "select",
      "id": "header_font_family",
      "label": "Title Font Family",
      "default": "inherit",
      "options": [
        { "value": "inherit", "label": "Inherit from page (Recommended)" },
        { "value": "system-ui, sans-serif", "label": "System Default" },
        { "value": "Helvetica, Arial, sans-serif", "label": "Helvetica" },
        { "value": "Georgia, serif", "label": "Georgia (Serif)" },
        { "value": "Inter, sans-serif", "label": "Inter (Modern)" },
        { "value": "Prompt, sans-serif", "label": "Prompt Black" },
        { "value": "Sonus-Medium, sans-serif", "label": "Sonus Medium" },
        { "value": "serif", "label": "Elegant Serif" }
      ]
    },
    {
      "type": "select",
      "id": "header_font_weight",
      "label": "Title Font Weight",
      "default": "700",
      "options": [
        { "value": "inherit", "label": "Inherit from page" },
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Normal (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "800", "label": "Extra Bold (800)" }
      ]
    },
    {
      "type": "header",
      "content": "Description"
    },
    {
      "type": "textarea",
      "id": "widget_description",
      "label": "Description Text",
      "default": "Upload an image of yourself and see your transformation"
    },
    {
      "type": "color",
      "id": "caption_color_1",
      "label": "Description Color 1 (Start)",
      "default": "#6b7280",
      "info": "First color for caption text gradient"
    },
    {
      "type": "color",
      "id": "caption_color_2",
      "label": "Description Color 2 (End)",
      "default": "#9ca3af",
      "info": "Second color for caption text gradient"
    },
    {
      "type": "range",
      "id": "description_font_size",
      "label": "Description Font Size (px)",
      "min": 10,
      "max": 24,
      "step": 1,
      "default": 16,
      "info": "Size of the description text"
    },
    {
      "type": "select",
      "id": "body_font_family",
      "label": "Description Font Family",
      "default": "inherit",
      "options": [
        { "value": "inherit", "label": "Inherit from page (Recommended)" },
        { "value": "system-ui, sans-serif", "label": "System Default" },
        { "value": "Helvetica, Arial, sans-serif", "label": "Helvetica" },
        { "value": "Georgia, serif", "label": "Georgia (Serif)" },
        { "value": "Inter, sans-serif", "label": "Inter (Modern)" },
        { "value": "Prompt, sans-serif", "label": "Prompt Black" },
        { "value": "Sonus-Medium, sans-serif", "label": "Sonus Medium" },
        { "value": "serif", "label": "Elegant Serif" }
      ]
    },
    {
      "type": "select",
      "id": "body_font_weight",
      "label": "Description Font Weight",
      "default": "inherit",
      "options": [
        { "value": "inherit", "label": "Inherit from page" },
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Normal (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" }
      ]
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Take A Photo"
    },
    {
      "type": "color",
      "id": "primary_color_1",
      "label": "Button Color 1 (Start)",
      "default": "#1f2937",
      "info": "First color for button gradient"
    },
    {
      "type": "color",
      "id": "primary_color_2",
      "label": "Button Color 2 (End)",
      "default": "#111827",
      "info": "Second color for button gradient"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text Color",
      "default": "#ffffff",
      "info": "Text color for buttons"
    },
    {
      "type": "header",
      "content": "Placeholder Image"
    },
    {
      "type": "image_picker",
      "id": "placeholder_image",
      "label": "Custom Placeholder Image",
      "info": "Upload a custom before/after preview image."
    },
    {
      "type": "header",
      "content": "Widget Container"
    },
    {
      "type": "textarea",
      "id": "disclaimer_text",
      "label": "Disclaimer Text",
      "default": "Results are not guaranteed, just a generated image. Images are never saved.",
      "info": "Text shown at the bottom of the widget"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Info Icon Color",
      "default": "#1f2937",
      "info": "Color for star and other icons"
    },
    {
      "type": "checkbox",
      "id": "enable_widget_shadow",
      "label": "Enable Widget Drop Shadow",
      "default": true,
      "info": "Toggle the shadow effect around the entire widget"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Widget Background",
      "default": "#ffffff",
      "info": "Background color of the entire widget"
    },
    {
      "type": "range",
      "id": "widget_border_radius",
      "label": "Widget Corner Radius (px)",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 16,
      "info": "Roundness of the entire widget container corners (0 = square, 40 = very rounded)"
    },
    {
      "type": "range",
      "id": "widget_margin_top",
      "label": "Margin Top (px)",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 20,
      "info": "Space above the widget"
    },
    {
      "type": "range",
      "id": "widget_margin_bottom",
      "label": "Margin Bottom (px)",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 20,
      "info": "Space below the widget"
    }
  ]
}
{% endschema %} 