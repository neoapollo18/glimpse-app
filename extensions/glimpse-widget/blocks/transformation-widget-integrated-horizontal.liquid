    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Widget Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Widget Border Color",
      "default": "#e5e7eb",
