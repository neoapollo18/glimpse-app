      "type": "range",
      "id": "button_border_width",
      "label": "Button Border Width (px)",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 2
    },
    {
      "type": "header",
      "content": "Placeholder Images"
    },
    {
      "type": "image_picker",
      "id": "placeholder_image",
      "label": "Custom Combined Image",
      "info": "Upload a single before/after preview image (recommended: 600x300px). Takes priority over separate images."
    },
    {
      "type": "image_picker",
      "id": "placeholder_before_image",
      "label": "Before Image (Left Side)",
      "info": "Upload a separate 'before' image for the left side"
    },
    {
      "type": "image_picker",
      "id": "placeholder_after_image",
      "label": "After Image (Right Side)",
      "info": "Upload a separate 'after' image for the right side"
    },
    {
      "type": "range",
      "id": "placeholder_height",
      "label": "Placeholder Height (%)",
