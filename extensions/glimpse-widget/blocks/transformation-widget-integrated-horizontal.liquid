{% liquid
  assign product = block.settings.product | default: product
  unless product
    assign product = product
  endunless
  
  assign product_id = product.id
  
  # Colors
  assign solid_button_color = block.settings.solid_button_color | default: '#1f2937'
  assign background_color = block.settings.background_color | default: '#ffffff'
  assign text_color = block.settings.text_color | default: '#1f2937'
  assign description_color = block.settings.description_color | default: '#6b7280'
  assign button_text_color = block.settings.button_text_color | default: '#ffffff'
  assign border_color = block.settings.border_color | default: '#e5e7eb'
  assign manual_shop_domain = block.settings.manual_shop_domain
  
  # Layout
  assign widget_margin_top = block.settings.widget_margin_top | default: 20
  assign widget_margin_bottom = block.settings.widget_margin_bottom | default: 20
  assign widget_padding = 24
  assign title_font_size = block.settings.title_font_size | default: 24
  assign description_font_size = block.settings.description_font_size | default: 16
  assign disclaimer_text = block.settings.disclaimer_text | default: 'Results are never guaranteed, just a generated image. Images are never saved.'
  
  # Widget container styling
  assign widget_border_radius = block.settings.widget_border_radius | default: 16
  assign enable_container = block.settings.enable_container | default: false
  assign enable_widget_shadow = true
  assign enable_widget_border = true
  
  # Handle "no container" mode
  if enable_container == false
    assign background_color = 'transparent'
    assign enable_widget_shadow = false
    assign enable_widget_border = false
  endif
  
  # Button styling
  assign button_style = block.settings.button_style | default: 'solid'
  assign button_text_case = 'none'
  assign button_border_radius = block.settings.button_border_radius | default: 12
  assign show_camera_icon = block.settings.show_camera_icon
  assign enable_button_border = block.settings.enable_button_border
  assign button_border_color = block.settings.button_border_color | default: '#1f2937'
  assign button_border_width = block.settings.button_border_width | default: 2
  
  # Image styling
  assign enable_image_border = block.settings.enable_image_border
  assign image_border_color = block.settings.image_border_color | default: '#1f2937'
  assign image_border_width = block.settings.image_border_width | default: 3
  assign image_border_radius = block.settings.image_border_radius | default: 12
  assign placeholder_height = block.settings.placeholder_height | default: 100
  
  # Typography
  assign header_font_family = block.settings.header_font_family | default: 'inherit'
  assign header_font_weight = block.settings.header_font_weight | default: '400'
  assign body_font_family = block.settings.body_font_family | default: 'inherit'
  assign body_font_weight = block.settings.body_font_weight | default: '400'
  
  # Computed styles
  if enable_widget_shadow
    assign widget_shadow = '0 4px 20px rgba(0, 0, 0, 0.08)'
  else
    assign widget_shadow = 'none'
  endif
  
  if enable_widget_border
    assign widget_border = '1px solid ' | append: border_color
  else
    assign widget_border = 'none'
  endif
%}

<!-- Gleame AI Transformation Widget - Integrated Horizontal Design -->
<div class="glimpse-integrated-horizontal{% unless enable_container %} no-container{% endunless %}" 
     data-product-id="{{ product_id }}"
     data-block-id="{{ block.id }}"{% if manual_shop_domain != blank %}
     data-manual-shop-domain="{{ manual_shop_domain }}"{% endif %}
     style="--solid-button-color: {{ solid_button_color }};
            --background-color: {{ background_color }}; 
            --text-color: {{ text_color }};
            --description-color: {{ description_color }};
            --button-text-color: {{ button_text_color }};
            --border-color: {{ border_color }};
            --widget-margin-top: {{ widget_margin_top }}px;
            --widget-margin-bottom: {{ widget_margin_bottom }}px;
            --widget-padding: {{ widget_padding }}px;
            --widget-border-radius: {{ widget_border_radius }}px;
            --widget-shadow: {{ widget_shadow }};
            --widget-border: {{ widget_border }};
            --title-font-size: {{ title_font_size }}px;
            --description-font-size: {{ description_font_size }}px;
            --button-border-radius: {{ button_border_radius }}px;
            --button-text-case: {{ button_text_case }};
            --button-border: {% if enable_button_border %}{{ button_border_width }}px solid {{ button_border_color }}{% else %}none{% endif %};
            --image-border: {% if enable_image_border %}{{ image_border_width }}px solid {{ image_border_color }}{% else %}none{% endif %};
            --image-border-radius: {{ image_border_radius }}px;
            --placeholder-height-mult: {{ placeholder_height | divided_by: 100.0 }};
            --header-font-family: {{ header_font_family }};
            --header-font-weight: {{ header_font_weight }};
            --body-font-family: {{ body_font_family }};
            --body-font-weight: {{ body_font_weight }};">
  
  <!-- Horizontal Layout: Text Left, Images Right -->
  <div class="horizontal-top-section">
    <!-- Left Side: Text Content -->
    <div class="horizontal-text-side">
      <h2 class="horizontal-title">{{ block.settings.widget_title | default: "Try It Virtually" }}</h2>
      <p class="horizontal-description">{{ block.settings.widget_description | default: "Upload an image of yourself and see your transformation" }}</p>
    </div>
    
    <!-- Right Side: Images -->
    <div class="horizontal-images-side">
      <!-- Initial/Upload State -->
      <div class="upload-state" id="uploadState-{{ block.id }}">
        <div class="horizontal-placeholder" onclick="window.widgetFunctions.triggerFileInputHorizontal('{{ block.id }}')">
          {% if block.settings.placeholder_image %}
            <!-- Single combined before/after image -->
            <img src="{{ block.settings.placeholder_image | image_url: width: 600 }}" 
                 alt="Transformation preview" 
                 class="horizontal-placeholder-image"
                 width="600"
                 height="300"
                 loading="lazy">
          {% elsif block.settings.placeholder_before_image or block.settings.placeholder_after_image %}
            <!-- Separate before/after images -->
            <div class="horizontal-default-placeholder">
              <div class="placeholder-side placeholder-before-side">
                {% if block.settings.placeholder_before_image %}
                  <img src="{{ block.settings.placeholder_before_image | image_url: width: 300 }}" 
                       alt="Before" 
                       class="placeholder-side-image"
                       loading="lazy">
                {% else %}
                  <div class="placeholder-silhouette"></div>
                {% endif %}
              </div>
              <div class="placeholder-side placeholder-after-side">
                {% if block.settings.placeholder_after_image %}
                  <img src="{{ block.settings.placeholder_after_image | image_url: width: 300 }}" 
                       alt="After" 
                       class="placeholder-side-image"
                       loading="lazy">
                {% else %}
                  <div class="placeholder-silhouette placeholder-silhouette-glow"></div>
                {% endif %}
              </div>
            </div>
          {% else %}
            <!-- Default side-by-side placeholder -->
            <div class="horizontal-default-placeholder">
              <div class="placeholder-side placeholder-before-side">
                <div class="placeholder-silhouette"></div>
              </div>
              <div class="placeholder-side placeholder-after-side">
                <div class="placeholder-silhouette placeholder-silhouette-glow"></div>
              </div>
            </div>
          {% endif %}
        </div>
      </div>
      
      <!-- Processing State -->
      <div class="processing-state" id="processingState-{{ block.id }}" style="display: none;">
        <div class="horizontal-loading">
          <p class="loading-text"><span class="loading-spinner"></span><span class="loading-text-content">Analyzing image...</span></p>
        </div>
      </div>
      
      <!-- Results State -->
      <div class="results-state" id="resultsState-{{ block.id }}" style="display: none;">
        <div class="horizontal-results">
          <div class="horizontal-comparison">
            <div class="comparison-side">
              <img id="beforeImage-{{ block.id }}" alt="Before" class="comparison-img" width="300" height="300">
            </div>
            <div class="comparison-side">
              <img id="afterImage-{{ block.id }}" alt="After" class="comparison-img" width="300" height="300">
            </div>
          </div>
        </div>
      </div>
      
      <!-- Error State -->
      <div class="error-state" id="errorState-{{ block.id }}" style="display: none;">
        <div class="horizontal-error">
          <svg class="error-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <path d="M12 8v4"/>
            <path d="M12 16h.01"/>
          </svg>
          <p class="error-message" id="errorMessage-{{ block.id }}"></p>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Hidden file input -->
  <input type="file" 
         id="imageUpload-{{ block.id }}" 
         accept="image/*,.heic,.heif" 
         style="display: none;">
  
  <!-- Button Section (Full Width) -->
  <div class="horizontal-button-section">
    <!-- Upload Button (shown in upload state) -->
    <button class="horizontal-upload-button button-style-{{ button_style }} upload-btn" 
            id="uploadButton-{{ block.id }}"
            type="button" 
            onclick="window.widgetFunctions.triggerFileInputHorizontal('{{ block.id }}')">
      {% if show_camera_icon %}
        <svg class="camera-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/>
          <circle cx="12" cy="13" r="3"/>
        </svg>
      {% endif %}
      <span class="button-text">{{ block.settings.button_text | default: "Upload a Photo" }}</span>
    </button>
    
    <!-- Try Again Button (shown in results/error state) -->
    <button class="horizontal-upload-button button-style-{{ button_style }} retry-btn" 
            id="retryButton-{{ block.id }}"
            type="button" 
            style="display: none;"
            onclick="window.widgetFunctions.resetTransformationHorizontal('{{ block.id }}')">
      <svg class="retry-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/>
        <path d="M21 3v5h-5"/>
        <path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/>
        <path d="M3 21v-5h5"/>
      </svg>
      <span class="button-text">{{ 'transformation.try_again' | t: default: 'Try Again' }}</span>
    </button>
  </div>
  
  <!-- Widget Footer / Disclaimer -->
  <div class="horizontal-footer">
    <svg class="info-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="10"/>
      <path d="M12 16v-4"/>
      <path d="M12 8h.01"/>
    </svg>
    <p class="horizontal-disclaimer">{{ disclaimer_text }}</p>
  </div>
  
</div>

<script src="{{ 'widget-integrated-horizontal.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Gleame Horizontal",
  "target": "section",
  "stylesheet": "transformation-widget-integrated-horizontal.css",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product",
      "autofill": true
    },
    {
      "type": "header",
      "content": "Configuration"
    },
    {
      "type": "text",
      "id": "manual_shop_domain",
      "label": "Shop Domain (Optional)",
      "placeholder": "shop123.myshopify.com",
      "info": "If using a custom domain, enter your .myshopify.com domain here."
    },
    {
      "type": "header",
      "content": "Title"
    },
    {
      "type": "text",
      "id": "widget_title",
      "label": "Title Text",
      "default": "Try It Virtually"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Title Color",
      "default": "#1f2937"
    },
    {
      "type": "range",
      "id": "title_font_size",
      "label": "Title Font Size (px)",
      "min": 16,
      "max": 40,
      "step": 2,
      "default": 24
    },
    {
      "type": "select",
      "id": "header_font_family",
      "label": "Title Font",
      "default": "inherit",
      "options": [
        { "value": "inherit", "label": "Inherit from theme (Recommended)" },
        { "value": "system-ui, sans-serif", "label": "System Default" },
        { "value": "Helvetica, Arial, sans-serif", "label": "Helvetica" },
        { "value": "Georgia, serif", "label": "Georgia (Serif)" },
        { "value": "Inter, sans-serif", "label": "Inter (Modern)" },
        { "value": "Prompt, sans-serif", "label": "Prompt" },
        { "value": "Sonus-Medium, sans-serif", "label": "Sonus Medium" },
        { "value": "serif", "label": "Elegant Serif" }
      ]
    },
    {
      "type": "select",
      "id": "header_font_weight",
      "label": "Title Font Weight",
      "default": "500",
      "options": [
        { "value": "inherit", "label": "Inherit from theme" },
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Normal (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "800", "label": "Extra Bold (800)" }
      ]
    },
    {
      "type": "header",
      "content": "Description"
    },
    {
      "type": "textarea",
      "id": "widget_description",
      "label": "Description Text",
      "default": "Upload an image of yourself and see your transformation"
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description Color",
      "default": "#6b7280"
    },
    {
      "type": "range",
      "id": "description_font_size",
      "label": "Description Font Size (px)",
      "min": 12,
      "max": 20,
      "step": 1,
      "default": 16
    },
    {
      "type": "select",
      "id": "body_font_family",
      "label": "Description Font",
      "default": "inherit",
      "options": [
        { "value": "inherit", "label": "Inherit from theme (Recommended)" },
        { "value": "system-ui, sans-serif", "label": "System Default" },
        { "value": "Helvetica, Arial, sans-serif", "label": "Helvetica" },
        { "value": "Georgia, serif", "label": "Georgia (Serif)" },
        { "value": "Inter, sans-serif", "label": "Inter (Modern)" },
        { "value": "Prompt, sans-serif", "label": "Prompt" },
        { "value": "Sonus-Medium, sans-serif", "label": "Sonus Medium" },
        { "value": "serif", "label": "Elegant Serif" }
      ]
    },
    {
      "type": "select",
      "id": "body_font_weight",
      "label": "Description Font Weight",
      "default": "300",
      "options": [
        { "value": "inherit", "label": "Inherit from theme" },
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Normal (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" }
      ]
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Upload a Photo"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button Style",
      "default": "solid",
      "options": [
        { "value": "solid", "label": "Solid Filled" },
        { "value": "outlined", "label": "Outlined" }
