    {
      "type": "range",
      "id": "widget_border_radius",
      "label": "Widget Corner Radius (px)",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 16
    },
    {
      "type": "range",
      "id": "widget_margin_top",
      "label": "Margin Top (px)",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 20
    },
    {
      "type": "range",
      "id": "widget_margin_bottom",
      "label": "Margin Bottom (px)",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 20
    }
  ]
}
{% endschema %}

