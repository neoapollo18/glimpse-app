    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Image Corner Radius (px)",
      "min": 0,
      "max": 30,
      "step": 2,
      "default": 12
    },
    {
      "type": "header",
      "content": "Widget Container"
    },
    {
      "type": "textarea",
      "id": "disclaimer_text",
      "label": "Disclaimer Text",
      "default": "Results are never guaranteed, just a generated image. Images are never saved."
    },
    {
      "type": "checkbox",
      "id": "enable_container",
