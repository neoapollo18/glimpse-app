      "default": true,
      "info": "Display camera icon in the upload button"
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Button Corner Radius (px)",
      "min": 0,
      "max": 50,
      "step": 2,
      "default": 12,
