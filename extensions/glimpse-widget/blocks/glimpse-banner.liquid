{% liquid
  assign product = block.settings.product | default: product
  unless product
    assign product = product
  endunless
  
  assign product_id = product.id
  assign manual_shop_domain = block.settings.manual_shop_domain
  
  # Banner content
  assign banner_image = block.settings.banner_image
  assign title_text = block.settings.title_text | default: 'VIRTUAL TRY-ON'
  assign description_text = block.settings.description_text | default: 'Upload a photo to see your transformation'
  assign button_text = block.settings.button_text | default: 'discover now'
  
  # Layout
  assign banner_height = block.settings.banner_height | default: 500
  assign content_alignment = block.settings.content_alignment | default: 'center'
  assign content_position = block.settings.content_position | default: 'center'
  assign content_max_width = block.settings.content_max_width | default: 600
  assign banner_padding = block.settings.banner_padding | default: 40
  
  # Typography
  assign title_size = block.settings.title_size | default: 42
  assign title_weight = block.settings.title_weight | default: '700'
  assign title_case = block.settings.title_case | default: 'uppercase'
  assign description_size = block.settings.description_size | default: 18
  assign description_weight = block.settings.description_weight | default: '400'
  
  # Colors
  assign title_color = block.settings.title_color | default: '#1f2937'
  assign description_color = block.settings.description_color | default: '#4b5563'
  assign overlay_color = block.settings.overlay_color | default: '#ffffff'
  assign overlay_opacity = block.settings.overlay_opacity | default: 0
  
  # Button styling
  assign button_style = block.settings.button_style | default: 'outlined'
  assign button_text_case = block.settings.button_text_case | default: 'lowercase'
  assign button_border_radius = block.settings.button_border_radius | default: 4
  assign button_padding_x = block.settings.button_padding_x | default: 32
  assign button_padding_y = block.settings.button_padding_y | default: 14
  assign button_font_size = block.settings.button_font_size | default: 14
  assign show_camera_icon = block.settings.show_camera_icon
  
  # Button colors
  assign primary_color_1 = block.settings.primary_color_1 | default: '#8b5cf6'
  assign primary_color_2 = block.settings.primary_color_2 | default: '#7c3aed'
  assign solid_button_color = block.settings.solid_button_color | default: '#1f2937'
  assign button_text_color = block.settings.button_text_color | default: '#1f2937'
  assign button_border_color = block.settings.button_border_color | default: '#d1d5db'
  
  # Results
  assign results_background = block.settings.results_background | default: '#ffffff'
  assign image_border_radius = block.settings.image_border_radius | default: 8
%}

<!-- Glimpse Banner Widget -->
<div class="glimpse-banner-widget" 
     data-product-id="{{ product_id }}"{% if manual_shop_domain != blank %}
     data-manual-shop-domain="{{ manual_shop_domain }}"{% endif %}
     style="--banner-height: {{ banner_height }}px;
            --content-alignment: {{ content_alignment }};
            --content-position: {{ content_position }};
            --content-max-width: {{ content_max_width }}px;
            --banner-padding: {{ banner_padding }}px;
            --title-size: {{ title_size }}px;
            --title-weight: {{ title_weight }};
            --title-case: {{ title_case }};
            --title-color: {{ title_color }};
            --description-size: {{ description_size }}px;
            --description-weight: {{ description_weight }};
            --description-color: {{ description_color }};
            --overlay-color: {{ overlay_color }};
            --overlay-opacity: {{ overlay_opacity }};
            --button-border-radius: {{ button_border_radius }}px;
            --button-padding-x: {{ button_padding_x }}px;
            --button-padding-y: {{ button_padding_y }}px;
            --button-font-size: {{ button_font_size }}px;
            --button-text-case: {{ button_text_case }};
            --button-text-color: {{ button_text_color }};
            --button-border-color: {{ button_border_color }};
            --solid-button-color: {{ solid_button_color }};
            --primary-color-1: {{ primary_color_1 }};
            --primary-color-2: {{ primary_color_2 }};
            --results-background: {{ results_background }};
            --image-border-radius: {{ image_border_radius }}px;">
  
  <!-- Banner Background -->
  <div class="banner-background">
    {% if banner_image %}
      <img src="{{ banner_image | image_url: width: 1920 }}" 
           alt="{{ title_text }}" 
           class="banner-bg-image"
           width="1920"
           height="{{ banner_height }}"
           loading="lazy">
    {% endif %}
    <div class="banner-overlay"></div>
  </div>
  
  <!-- Banner Content -->
  <div class="banner-content">
    
    <!-- Upload State -->
    <div class="banner-upload-state" id="uploadState">
      <div class="banner-text-content">
        <h2 class="banner-title">{{ title_text }}</h2>
        <p class="banner-description">{{ description_text }}</p>
      </div>
      
      <button class="banner-btn btn-style-{{ button_style }}" 
              type="button" 
              onclick="window.glimpseBanner.triggerUpload()">
        {% if show_camera_icon %}
          <svg class="btn-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/>
            <circle cx="12" cy="13" r="3"/>
          </svg>
        {% endif %}
        <span class="btn-text">{{ button_text }}</span>
      </button>
    </div>
    
    <!-- Hidden file input -->
    <input type="file" 
           id="imageUpload" 
           accept="image/*,.heic,.heif" 
           style="display: none;">
    
    <!-- Processing State -->
    <div class="banner-processing-state" id="processingState" style="display: none;">
      <div class="banner-loading">
        <div class="banner-spinner"></div>
        <span class="loading-text">Creating your look...</span>
      </div>
    </div>
    
    <!-- Results State -->
    <div class="banner-results-state" id="resultsState" style="display: none;">
      <div class="banner-results-container">
        <div class="banner-comparison">
          <div class="banner-comparison-side">
            <img id="beforeImage" alt="Before" class="banner-result-img" width="200" height="200">
          </div>
          <div class="banner-comparison-side">
            <img id="afterImage" alt="After" class="banner-result-img" width="200" height="200">
          </div>
        </div>
        <button class="banner-btn btn-style-{{ button_style }}" 
                type="button" 
                onclick="window.glimpseBanner.reset()">
          <svg class="btn-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/>
            <path d="M21 3v5h-5"/>
            <path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/>
            <path d="M3 21v-5h5"/>
          </svg>
          <span class="btn-text">Try Again</span>
        </button>
      </div>
    </div>
    
    <!-- Error State -->
    <div class="banner-error-state" id="errorState" style="display: none;">
      <div class="banner-error-container">
        <p class="banner-error-message" id="errorMessage"></p>
        <button class="banner-btn btn-style-{{ button_style }}" 
                type="button" 
                onclick="window.glimpseBanner.reset()">
          <span class="btn-text">Try Again</span>
        </button>
      </div>
    </div>
    
  </div>
</div>

<script src="{{ 'glimpse-banner.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Glimpse Banner",
  "target": "section",
  "stylesheet": "glimpse-banner.css",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product",
      "autofill": true
    },
    {
      "type": "header",
      "content": "Banner Content"
    },
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "title_text",
      "label": "Title",
      "default": "VIRTUAL TRY-ON"
    },
    {
      "type": "textarea",
      "id": "description_text",
      "label": "Description",
      "default": "Upload a photo to see your transformation"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "discover now"
    },
    {
      "type": "text",
      "id": "manual_shop_domain",
      "label": "Shop Domain (Optional)",
      "placeholder": "shop123.myshopify.com"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "banner_height",
      "label": "Banner Height (px)",
      "min": 300,
      "max": 800,
      "step": 50,
      "default": 500
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Text Alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "Content Position",
      "default": "center",
      "options": [
        { "value": "flex-start", "label": "Top" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Bottom" }
      ]
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "Content Max Width (px)",
      "min": 400,
      "max": 1000,
      "step": 50,
      "default": 600
    },
    {
      "type": "range",
      "id": "banner_padding",
      "label": "Padding (px)",
      "min": 20,
      "max": 80,
      "step": 10,
      "default": 40
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title Size (px)",
      "min": 24,
      "max": 72,
      "step": 2,
      "default": 42
    },
    {
      "type": "select",
      "id": "title_weight",
      "label": "Title Weight",
      "default": "700",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" }
      ]
    },
    {
      "type": "select",
      "id": "title_case",
      "label": "Title Case",
      "default": "uppercase",
      "options": [
        { "value": "none", "label": "As Typed" },
        { "value": "uppercase", "label": "UPPERCASE" },
        { "value": "lowercase", "label": "lowercase" }
      ]
    },
    {
      "type": "range",
      "id": "description_size",
      "label": "Description Size (px)",
      "min": 14,
      "max": 24,
      "step": 1,
      "default": 18
    },
    {
      "type": "select",
      "id": "description_weight",
      "label": "Description Weight",
      "default": "400",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" }
      ]
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title Color",
      "default": "#1f2937"
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description Color",
      "default": "#4b5563"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay Opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 0,
      "info": "0 = transparent, 100 = solid"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button Style",
      "default": "outlined",
      "options": [
        { "value": "gradient", "label": "Gradient Filled" },
        { "value": "solid", "label": "Solid Filled" },
        { "value": "outlined", "label": "Outlined" }
      ]
    },
    {
      "type": "select",
      "id": "button_text_case",
      "label": "Button Text Case",
      "default": "lowercase",
      "options": [
        { "value": "none", "label": "As Typed" },
        { "value": "uppercase", "label": "UPPERCASE" },
        { "value": "lowercase", "label": "lowercase" }
      ]
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Button Radius (px)",
      "min": 0,
      "max": 50,
      "step": 2,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_camera_icon",
      "label": "Show Camera Icon",
      "default": false
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text Color",
      "default": "#1f2937"
    },
    {
      "type": "color",
      "id": "button_border_color",
      "label": "Button Border Color",
      "default": "#d1d5db"
    },
    {
      "type": "color",
      "id": "solid_button_color",
      "label": "Solid Fill Color",
      "default": "#1f2937"
    },
    {
      "type": "color",
      "id": "primary_color_1",
      "label": "Gradient Start",
      "default": "#8b5cf6"
    },
    {
      "type": "color",
      "id": "primary_color_2",
      "label": "Gradient End",
      "default": "#7c3aed"
    }
  ]
}
{% endschema %}

