{
  "$comment": "Locks & Mane brand config for compile-brand-flow.cjs. Everything brand-specific lives HERE; the compiler and the runtime engine are generic. Encodes the 2026-07 spec: Rule Set 1 (accessory branch by style intent), Rule Set 2 (sets count from layers/thickness/length), Rule Set 3 (length matrix), Rule Set 4 (shade maps). Remaining TODOs: real shop domain, exact Gleame product names once the catalog is imported, Jenn's real 10 shades + pony shade map + fallback adjacencies. Product/variant names must match the Gleame-configured names exactly.",

  "shopDomain": "TODO-locksandmane.myshopify.com",

  "availabilityFilter": true,

  "axes": [
    {
      "key": "category",
      "label": "Shopping for",
      "source": "user_question",
      "values": [
        { "value": "extensions", "label": "Extensions" },
        { "value": "accessories", "label": "Accessories" }
      ]
    },
    {
      "key": "goal",
      "label": "Hair goal",
      "source": "user_question",
      "values": [
        { "value": "length", "label": "More Length" },
        { "value": "volume", "label": "More Volume" },
        { "value": "both", "label": "Both" }
      ]
    },
    {
      "key": "style_intent",
      "label": "The look",
      "source": "user_question",
      "$comment": "Drives accessory picks (Rule Set 1). Filler for extensions — no extension rule keys on it.",
      "values": [
        { "value": "everyday", "label": "Everyday wear" },
        { "value": "special_event", "label": "A special event" },
        { "value": "vacation", "label": "Vacation" },
        { "value": "photoshoot", "label": "Photoshoot or content" },
        { "value": "choose_for_me", "label": "Surprise Me" }
      ]
    },
    {
      "key": "current_length",
      "label": "Current hair length",
      "source": "user_question",
      "values": [
        { "value": "above_shoulders", "label": "Above my shoulders" },
        { "value": "at_shoulders", "label": "At my shoulders" },
        { "value": "past_shoulders", "label": "Past my shoulders" },
        { "value": "mid_back", "label": "Down to my mid-back" }
      ]
    },
    {
      "key": "thickness",
      "label": "Hair thickness",
      "source": "user_question",
      "values": [
        { "value": "thin", "label": "On the thinner side" },
        { "value": "medium", "label": "Medium" },
        { "value": "thick", "label": "On the thicker side" }
      ]
    },
    {
      "key": "layers",
      "label": "Layers",
      "source": "user_question",
      "values": [
        { "value": "yes", "label": "Yes" },
        { "value": "no", "label": "No" }
      ]
    },
    {
      "key": "hair_shade",
      "label": "Natural hair shade",
      "source": "photo",
      "$comment": "TODO Jenn: L&M's real 10-shade range with swatch hexes. Placeholders below keep the compiler runnable.",
      "values": [
        { "value": "jet_black", "label": "Jet Black", "swatchColor": "#0e0d0d" },
        { "value": "soft_black", "label": "Soft Black", "swatchColor": "#1c1715" },
        { "value": "darkest_brown", "label": "Darkest Brown", "swatchColor": "#2b1e16" },
        { "value": "dark_brown", "label": "Dark Brown", "swatchColor": "#3d2a1c" },
        { "value": "chestnut_brown", "label": "Chestnut Brown", "swatchColor": "#54371f" },
        { "value": "light_brown", "label": "Light Brown", "swatchColor": "#6e4a2a" },
        { "value": "dark_blonde", "label": "Dark Blonde", "swatchColor": "#8d6a3f" },
        { "value": "golden_blonde", "label": "Golden Blonde", "swatchColor": "#b08d57" },
        { "value": "ash_blonde", "label": "Ash Blonde", "swatchColor": "#c2ab8a" },
        { "value": "platinum_blonde", "label": "Platinum Blonde", "swatchColor": "#e3d3b7" }
      ]
    }
  ],

  "questions": [
    {
      "axisKey": "category",
      "prompt": "What are you looking for today?"
    },
    {
      "axisKey": "goal",
      "prompt": "What are you hoping to change about your hair?",
      "showIf": { "axis_key": "category", "axis_value": "extensions" }
    },
    {
      "axisKey": "style_intent",
      "prompt": "What's the look for?"
    },
    {
      "axisKey": "current_length",
      "prompt": "Where does your hair fall right now?",
      "showIf": { "axis_key": "category", "axis_value": "extensions" }
    },
    {
      "axisKey": "thickness",
      "prompt": "How thick is your hair?",
      "showIf": { "axis_key": "category", "axis_value": "extensions" }
    },
    {
      "axisKey": "layers",
      "prompt": "Do you have layers?",
      "showIf": { "axis_key": "category", "axis_value": "extensions" },
      "options": [
        { "label": "Yes", "value": "yes" },
        { "label": "No", "value": "no" },
        { "label": "I’m not sure", "value": "no" }
      ]
    }
  ],

  "products": {
    "$comment": "Gleame product names (must match products.product_name exactly). TODO: confirm once the L&M catalog is configured. pony_14 kept because Example Response 2 references a 14″ ponytail even though the matrix only uses 18″.",
    "clip_12": "12\" Clip-In",
    "clip_16": "16\" Clip-In",
    "clip_18": "18\" Clip-In",
    "clip_20": "20\" Clip-In",
    "pony_14": "14\" Ponytail",
    "pony_18": "18\" Ponytail"
  },

  "shadeVariantMap": {
    "$comment": "hair_shade axis value → variant_title per product family (Rule Set 4). clip_in is identity (clip-ins use the AI shade directly); ponytail is Jenn's lookup map — TODO Jenn: real mapping, placeholders are identity for now.",
    "clip_in": {
      "jet_black": "Jet Black", "soft_black": "Soft Black", "darkest_brown": "Darkest Brown",
      "dark_brown": "Dark Brown", "chestnut_brown": "Chestnut Brown", "light_brown": "Light Brown",
      "dark_blonde": "Dark Blonde", "golden_blonde": "Golden Blonde", "ash_blonde": "Ash Blonde",
      "platinum_blonde": "Platinum Blonde"
    },
    "ponytail": {
      "jet_black": "Jet Black", "soft_black": "Soft Black", "darkest_brown": "Darkest Brown",
      "dark_brown": "Dark Brown", "chestnut_brown": "Chestnut Brown", "light_brown": "Light Brown",
      "dark_blonde": "Dark Blonde", "golden_blonde": "Golden Blonde", "ash_blonde": "Ash Blonde",
      "platinum_blonde": "Platinum Blonde"
    }
  },

  "shadeFallbacks": {
    "$comment": "TODO Jenn: nearest-shade adjacencies (used only when the availability filter finds a shade fully out of stock). Written to chat_assistant_config.quiz_shade_fallbacks. Placeholder = simple neighbors in the depth scale above.",
    "hair_shade": {
      "jet_black": ["soft_black", "darkest_brown"],
      "soft_black": ["jet_black", "darkest_brown"],
      "darkest_brown": ["dark_brown", "soft_black"],
      "dark_brown": ["darkest_brown", "chestnut_brown"],
      "chestnut_brown": ["dark_brown", "light_brown"],
      "light_brown": ["chestnut_brown", "dark_blonde"],
      "dark_blonde": ["light_brown", "golden_blonde"],
      "golden_blonde": ["dark_blonde", "ash_blonde"],
      "ash_blonde": ["golden_blonde", "platinum_blonde"],
      "platinum_blonde": ["ash_blonde", "golden_blonde"]
    }
  },

  "setsTable": {
    "$comment": "Rule Set 2 — how many sets, first matching row wins. 'lengths' restricts a row to specific current_length values (omitted = any). The compiled quantity is max(this table, the matrix cell's own sets) — so goal=both keeps 2 sets even for layered/thin hair. OPEN QUESTION flagged to Christa/Jenn: should Rule Set 2 be able to LOWER a both-goal cell to 1 set instead?",
    "rows": [
      { "layers": "yes", "sets": 1 },
      { "layers": "no", "thickness": "thin", "sets": 1 },
      { "layers": "no", "thickness": "medium", "lengths": ["above_shoulders"], "sets": 1 },
      { "layers": "no", "thickness": "medium", "lengths": ["at_shoulders", "past_shoulders", "mid_back"], "sets": 2 },
      { "layers": "no", "thickness": "thick", "sets": 2 }
    ]
  },

  "matrix": {
    "$comment": "Rule Set 3 — current_length × goal → hero clip-in (+sets) and optional complementary ponytail. 'pony' omitted = single-recommendation cell (above-shoulders row and at-shoulders+volume have no ponytail in Christa's table). Above-shoulders row: the source table shows one entry spanning all goals — encoded as 16″ × 2 sets for every goal; FLAGGED for confirmation.",
    "cells": [
      { "current_length": "above_shoulders", "goal": "length", "clipIn": "clip_16", "sets": 2 },
      { "current_length": "above_shoulders", "goal": "volume", "clipIn": "clip_16", "sets": 2 },
      { "current_length": "above_shoulders", "goal": "both",   "clipIn": "clip_16", "sets": 2 },
      { "current_length": "at_shoulders",    "goal": "length", "clipIn": "clip_16", "sets": 1, "pony": "pony_18" },
      { "current_length": "at_shoulders",    "goal": "volume", "clipIn": "clip_12", "sets": 1 },
      { "current_length": "at_shoulders",    "goal": "both",   "clipIn": "clip_16", "sets": 2, "pony": "pony_18" },
      { "current_length": "past_shoulders",  "goal": "length", "clipIn": "clip_18", "sets": 1, "pony": "pony_18" },
      { "current_length": "past_shoulders",  "goal": "volume", "clipIn": "clip_16", "sets": 1, "pony": "pony_18" },
      { "current_length": "past_shoulders",  "goal": "both",   "clipIn": "clip_18", "sets": 2, "pony": "pony_18" },
      { "current_length": "mid_back",        "goal": "length", "clipIn": "clip_20", "sets": 1, "pony": "pony_18" },
      { "current_length": "mid_back",        "goal": "volume", "clipIn": "clip_18", "sets": 1, "pony": "pony_18" },
      { "current_length": "mid_back",        "goal": "both",   "clipIn": "clip_20", "sets": 2, "pony": "pony_18" }
    ]
  },

  "accessories": {
    "$comment": "Rule Set 1 — top 3 accessories per style intent; category=accessories exits here (extension questions are showIf-hidden). Names derived from the locksandmane.com handles provided 2026-07-15, ASSUMING the 15-URL list reads column-by-column (3 per intent) — confirm with Jenn. 'handle' is reference only; the compiler resolves by name.",
    "byStyleIntent": {
      "everyday": [
        { "name": "Denim Headband", "handle": "denim-headband" },
        { "name": "Flourette Gem Stone Headband", "handle": "flourette-gem-stone-headband" },
        { "name": "Embroidered Floral Headband", "handle": "embroidered-floral-headband" }
      ],
      "special_event": [
