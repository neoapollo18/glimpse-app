      ],
      "vacation": [
        { "name": "Diamond Veil Headband", "handle": "diamond-veil-headband" },
        { "name": "Cozumel Headband", "handle": "cozumel-headband" },
        { "name": "Midsummer Nights Dream Headband", "handle": "midsummer-nights-dream-headband" }
      ],
      "photoshoot": [
        { "name": "Vintage Gem Headband Mint Green", "handle": "vintage-gem-headband-mint-green" },
        { "name": "So 90s Barrette Set", "handle": "so-90s-barrette-set" },
        { "name": "Pearl Laurel Headband", "handle": "pearl-laurel-headband" }
      ],
      "choose_for_me": [
