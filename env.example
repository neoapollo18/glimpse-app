# Shopify App Configuration
# Get these from your Shopify Partner Dashboard (https://partners.shopify.com)
SHOPIFY_API_KEY=your_shopify_api_key_here
SHOPIFY_API_SECRET=your_shopify_api_secret_here

# Your app's public URL (e.g., https://your-app.onrender.com)
SHOPIFY_APP_URL=https://your-app-url.onrender.com

# Shopify API scopes (comma-separated, no spaces)
SCOPES=write_products

# Database Configuration
# For production, use a PostgreSQL connection string
# For local development, SQLite works: file:./dev.sqlite
DATABASE_URL=postgresql://user:password@host:5432/database

# Supabase Configuration
# Get these from your Supabase project settings (https://app.supabase.com)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_API_KEY=your_supabase_anon_key_here

# AI Configuration
# Google Gemini API Key (currently used for AI transformations)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Environment
# Set to "production" for Render deployments
NODE_ENV=development

# Admin Panel Configuration
# Password for the founders admin panel (/admin route)
ADMIN_PASSWORD=your_admin_password_here

# Optional: Custom Shop Domain
# Only needed if using a custom shop domain
# SHOP_CUSTOM_DOMAIN=your-custom-domain.myshopify.com

